{
  "name": "jarvis",
  "version": "1.0.0",
  "description": "J.A.R.V.I.S. — Holographic AI Desktop Assistant",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -n \"VITE,ELECTRON\" -c \"cyan,blue\" \"vite --port 5173\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "vite": "vite --port 5173",
    "electron": "cross-env NODE_ENV=development electron .",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2",
    "framer-motion": "^11.3.0",
    "axios": "^1.7.2",
    "lucide-react": "^0.400.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.jarvis.ai",
    "productName": "JARVIS",
    "directories": { "output": "dist-electron" },
    "files": ["dist/**/*", "electron/**/*"],
    "win": { "target": "nsis" },
    "mac": { "category": "public.app-category.productivity" },
    "linux": { "target": "AppImage" }
  }
}